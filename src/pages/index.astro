---
import '@fontsource-variable/newsreader';
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/landing.css';

const desc =
	'AGP is an open, vendor-neutral protocol for governing AI agents — standardizing what an agent is allowed to do, who authorized it, and what it actually did, signed and verifiable across every vendor.';

// Rendered with set:html so the literal { } in the JSON aren't parsed as JSX expressions.
const eventCode = `<span class="c">// canonical AGP event (L2)</span>
{
  <span class="k">"agp_version"</span>: <span class="s">"0.1"</span>,
  <span class="k">"actor"</span>: { <span class="k">"vendor"</span>: <span class="s">"acme.com"</span>, <span class="k">"agent_id"</span>: <span class="s">"agt_42"</span> },
  <span class="k">"action"</span>: { <span class="k">"type"</span>: <span class="s">"tool_call"</span>, <span class="k">"tool_name"</span>: <span class="s">"email.send"</span> },
  <span class="k">"policy"</span>: { <span class="k">"decision"</span>: <span class="s">"blocked"</span>, <span class="k">"policy_hash"</span>: <span class="s">"sha256:9f2a…"</span> },
  <span class="k">"signature"</span>: { <span class="k">"alg"</span>: <span class="p">"Ed25519"</span>, <span class="k">"value"</span>: <span class="s">"base64…"</span> }
}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>OpenAGP — The Agent Governance Protocol</title>
		<meta name="description" content={desc} />
		<meta property="og:title" content="OpenAGP — The Agent Governance Protocol" />
		<meta property="og:description" content={desc} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://openagp.io" />
		<meta name="twitter:card" content="summary_large_image" />
		<script is:inline>
			// Apply theme before paint (no flash); shares the `starlight-theme` key with the docs.
			(() => {
				const stored = localStorage.getItem('starlight-theme');
				const t = stored === 'light' || stored === 'dark'
					? stored
					: (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
				document.documentElement.dataset.theme = t;
			})();
		</script>
	</head>
	<body>
		<!-- Top bar -->
		<header class="topbar">
			<div class="wrap">
				<a class="brand" href="/">
					<svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
						<path d="M20 3 L34 9 V20 C34 29 28 35 20 37 C12 35 6 29 6 20 V9 Z" fill="#2a6db8"></path>
						<path d="M20 3 L34 9 V20 C34 29 28 35 20 37 C12 35 6 29 6 20 V9 Z" stroke="#7c3aed" stroke-width="1.5"></path>
						<path d="M13.5 20.5 L18 25 L27 14.5" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
					<span>OpenAGP</span>
					<span class="v">v0.1 · draft</span>
				</a>
				<nav class="nav">
					<a href="/learn/what-is-agp/">Learn</a>
					<a href="/case-studies/">Case studies</a>
					<a href="/spec/">Spec</a>
					<a href="/registry/">Registry</a>
					<a href="/community/contribute/">Contribute</a>
					<a href="https://github.com/openagp">GitHub ↗</a>
					<button class="icon-btn" id="theme-toggle" type="button" aria-label="Toggle color theme" title="Toggle theme">
						<svg class="sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"></circle><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5L19 19M19 5l-1.5 1.5M6.5 17.5L5 19"></path></svg>
						<svg class="moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path></svg>
					</button>
				</nav>
			</div>
		</header>

		<!-- Hero: specification front-matter -->
		<div class="hero">
			<div class="wrap hero-grid">
				<div>
					<div class="doc-id">
						<span class="overline">Open specification</span>
						<span class="pill">agp / v0.1</span>
						<span class="pill">working draft</span>
					</div>
					<p class="eyebrow">The Agent Governance Protocol</p>
					<h1>What an agent is allowed to do, who said so, and what it actually did.</h1>
					<p class="byline">An open, vendor-neutral standard · <b>Maintained by the OpenAGP community</b> · CC BY 4.0</p>
					<p class="abstract-p">
						<span class="lbl">Abstract</span>
						AGP defines a small set of signed, schema-defined messages exchanged between a customer's
						governance plane and an agent vendor — so one policy can be enforced, and one verifiable
						audit trail produced, across every AI agent vendor. The way SAML standardized identity and
						MCP standardized tool-calling, AGP standardizes governance.
					</p>
					<div class="cta-row">
						<a class="btn" href="/spec/">Read the specification</a>
						<a class="textlink" href="/adopt/vendors/">Run the reference demo</a>
						<a class="textlink" href="https://github.com/openagp">Source &amp; SDKs</a>
					</div>
				</div>

				<aside class="docinfo" aria-label="Document information">
					<div class="h">Document</div>
					<dl>
						<div class="row"><dt>Identifier</dt><dd class="mono">agp/0.1</dd></div>
						<div class="row"><dt>Status</dt><dd>Working draft</dd></div>
						<div class="row"><dt>Flows</dt><dd>A · events &nbsp;B · policy &nbsp;C · decision</dd></div>
						<div class="row"><dt>Conformance</dt><dd>L1 → L2 → L3</dd></div>
						<div class="row"><dt>Signatures</dt><dd class="mono">Ed25519 · RFC 8785</dd></div>
						<div class="row"><dt>Implementations</dt><dd>Python · TypeScript · Go</dd></div>
						<div class="row"><dt>License</dt><dd>CC BY 4.0 / Apache-2.0</dd></div>
					</dl>
				</aside>
			</div>
		</div>

		<!-- §01 problem -->
		<section id="problem">
			<div class="wrap">
				<div class="sec-head reveal"><span class="num">§ 01</span><h2>The fragmentation problem</h2></div>
				<p class="sec-intro reveal">
					An enterprise will soon run hundreds of agents across dozens of vendors — each with its own
					audit format, its own policy surface, and its own identity model. There is no unified way to
					see what every agent did, enforce one policy, or prove it to an auditor. This is the problem
					identity had before SAML.
				</p>
				<div class="compare2 reveal">
					<div class="without">
						<h3>Without AGP</h3>
						<ul>
							<li>N vendors × M customers = N × M bespoke integrations</li>
							<li>Audit logs in N incompatible formats</li>
							<li>Policy authored separately for every vendor</li>
							<li>No cryptographic provenance — "trust us, the agent did this"</li>
							<li>One action across three vendors is three separate stories</li>
						</ul>
					</div>
					<div class="with">
						<h3>With AGP</h3>
						<ul>
							<li>N vendors × M customers = N + M integrations</li>
							<li>One canonical event schema, signed end-to-end</li>
							<li>One policy DSL, pushed to every vendor</li>
							<li>Every event signed; the ledger is hash-chained and verifiable</li>
							<li>One action is one event with verifiable lineage</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- §02 figure: three flows -->
		<section id="how">
			<div class="wrap">
				<div class="sec-head reveal"><span class="num">§ 02</span><h2>Three flows between plane &amp; vendor</h2></div>
				<figure class="reveal">
					<div class="figure-box">
						<svg class="diagram" viewBox="0 0 860 320" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The three AGP flows">
							<defs>
								<marker id="ar" markerWidth="9" markerHeight="9" refX="7" refY="3" orient="auto"><path d="M0 0 L7 3 L0 6 Z" fill="#14365c"></path></marker>
								<marker id="arb" markerWidth="9" markerHeight="9" refX="7" refY="3" orient="auto"><path d="M0 0 L7 3 L0 6 Z" fill="#2a6db8"></path></marker>
								<marker id="arp" markerWidth="9" markerHeight="9" refX="7" refY="3" orient="auto"><path d="M0 0 L7 3 L0 6 Z" fill="#7c3aed"></path></marker>
							</defs>
							<!-- nodes -->
							<rect class="node" x="40" y="120" width="170" height="80" rx="8"></rect>
							<text class="nlabel" x="125" y="155" text-anchor="middle">Customer</text>
							<text class="nlabel" x="125" y="174" text-anchor="middle">Plane</text>
							<rect class="node" x="650" y="120" width="170" height="80" rx="8"></rect>
							<text class="nlabel" x="735" y="155" text-anchor="middle">Agent</text>
							<text class="nlabel" x="735" y="174" text-anchor="middle">Vendor</text>
							<rect class="node" x="650" y="250" width="170" height="46" rx="8" stroke-dasharray="4 3"></rect>
							<text class="nlabel" x="735" y="278" text-anchor="middle" font-size="12">agent action</text>

							<!-- Flow B: plane -> vendor -->
							<path class="flow" stroke="#2a6db8" d="M214 142 H646" marker-end="url(#arb)"></path>
							<text class="flowlabel" x="430" y="134" text-anchor="middle" fill="#2a6db8">B · signed policy (L2)</text>

							<!-- Flow C: vendor <-> plane -->
							<path class="flow" stroke="#7c3aed" d="M646 165 H214" marker-end="url(#arp)"></path>
							<text class="flowlabel" x="430" y="160" text-anchor="middle" fill="#7c3aed">C · decision ≤ 300ms (L3)</text>

							<!-- Flow A: vendor -> plane -->
							<path class="flow" stroke="#14365c" d="M646 188 H214" marker-end="url(#ar)"></path>
							<text class="flowlabel" x="430" y="206" text-anchor="middle" fill="#14365c">A · signed event (L1, always)</text>

							<!-- agent to vendor -->
							<path class="flow" stroke="#8b93a1" d="M735 250 V200" marker-end="url(#ar)"></path>
						</svg>
					</div>
					<figcaption><b>Figure 1.</b> The three AGP flows. A vendor implements one or more and declares its conformance level; the same customer policy then works across every conformant vendor.</figcaption>
				</figure>
			</div>
		</section>

		<!-- §03 conformance -->
		<section id="conformance">
			<div class="wrap">
				<div class="sec-head reveal"><span class="num">§ 03</span><h2>Conformance levels</h2></div>
				<table class="levels reveal">
					<thead>
						<tr><th>Level</th><th>Vendor implements</th><th>What the customer gets</th><th>Cost to ship</th></tr>
					</thead>
					<tbody>
						<tr>
							<td class="lv">L1<small>events</small></td>
							<td>Flow A — emit signed canonical events</td>
							<td>Passive observability. Every action recorded with verifiable provenance.</td>
							<td class="cost">≤ 1 eng-week</td>
						</tr>
						<tr>
							<td class="lv">L2<small>governance</small></td>
							<td>Flow A + B — accept &amp; apply customer policy</td>
							<td>One policy DSL enforced inside every vendor; each event stamped with the policy in force.</td>
							<td class="cost">+ 1 eng-week</td>
						</tr>
						<tr>
							<td class="lv">L3<small>real-time</small></td>
							<td>Flow A + B + C — synchronous decision callback</td>
							<td>High-stakes actions gated by the plane in &lt;300ms. Human-in-the-loop as a protocol primitive.</td>
							<td class="cost">+ 2 eng-weeks</td>
						</tr>
					</tbody>
				</table>
			</div>
		</section>

		<!-- §04 verifiable -->
		<section id="verifiable">
			<div class="wrap">
				<div class="sec-head reveal"><span class="num">§ 04</span><h2>Verifiable by construction</h2></div>
				<div class="verify-grid">
					<div class="code reveal">
						<div class="code-bar">
							<span>event · evt_01JFXY8B…</span>
							<span class="verified">✓ signature verified</span>
						</div>
						<pre><code set:html={eventCode}></code></pre>
					</div>
					<ul class="verify-points reveal">
						<li><b>Signed end-to-end</b><span>Events and policies are Ed25519-signed and canonicalized with RFC 8785 (JCS) — the same bytes in every language.</span></li>
						<li><b>Independently checkable</b><span>An auditor verifies a vendor's signature against its registered key — without trusting the plane in between.</span></li>
						<li><b>Three implementations, byte-for-byte</b><span>Python, TypeScript, and a Go conformance suite agree on every byte. <code class="mono">agp-cts vectors</code> proves it.</span></li>
						<li><b>Provenance, not promises</b><span>Each event carries the <code class="mono">policy_hash</code> in force; the ledger is hash-chained and tamper-evident.</span></li>
					</ul>
				</div>
			</div>
		</section>

		<!-- §05 personas -->
		<section id="who">
			<div class="wrap">
				<div class="sec-head reveal"><span class="num">§ 05</span><h2>Who it's for</h2></div>
				<div class="personas reveal">
					<div class="persona">
						<span class="pn">Vendors</span>
						<h3>Ship L1 in a week</h3>
						<p>Emit signed events with a reference SDK; prove it with the conformance suite.</p>
						<a href="/adopt/vendors/">Start →</a>
					</div>
					<div class="persona">
						<span class="pn">Customers</span>
						<h3>One policy, everywhere</h3>
						<p>Author governance once; have it enforced and proven across every vendor.</p>
						<a href="/adopt/customers/">Start →</a>
					</div>
					<div class="persona">
						<span class="pn">Auditors</span>
						<h3>Evidence you verify</h3>
						<p>Standardized, signed artifacts — checkable without trusting any vendor.</p>
						<a href="/adopt/auditors/">Start →</a>
					</div>
					<div class="persona">
						<span class="pn">Contributors</span>
						<h3>Open spec, no CLA</h3>
						<p>Free SDKs, DCO sign-off, an open RFC process. Shape the standard.</p>
						<a href="/community/contribute/">Start →</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Footer -->
		<footer class="foot">
			<div class="wrap">
				<div>
					<a class="brand" href="/" style="margin-bottom:0.8rem;">
						<svg viewBox="0 0 40 40" fill="none" aria-hidden="true">
							<path d="M20 3 L34 9 V20 C34 29 28 35 20 37 C12 35 6 29 6 20 V9 Z" fill="#2a6db8"></path>
							<path d="M13.5 20.5 L18 25 L27 14.5" stroke="#fff" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round"></path>
						</svg>
						<span>OpenAGP</span>
					</a>
					<p class="meta">An open, vendor-neutral standard, with a roadmap to multi-stakeholder governance by v1.0. Spec CC BY 4.0 · SDKs Apache-2.0 · registry data CC0.</p>
				</div>
				<div class="cols">
					<div>
						<h4>Protocol</h4>
						<a href="/spec/">Specification</a>
						<a href="/spec/adr-0001/">Signing (ADR 0001)</a>
						<a href="/learn/conformance/">Conformance</a>
						<a href="/registry/">Registry</a>
					</div>
					<div>
						<h4>Adopt</h4>
						<a href="/adopt/vendors/">For vendors</a>
						<a href="/adopt/customers/">For customers</a>
						<a href="/adopt/auditors/">For auditors</a>
					</div>
					<div>
						<h4>Community</h4>
						<a href="https://github.com/openagp">GitHub</a>
						<a href="https://github.com/openagp/spec/discussions">Discussions</a>
						<a href="/community/contribute/">Get involved</a>
					</div>
				</div>
			</div>
		</footer>

		<script is:inline>
			const io = new IntersectionObserver((entries) => {
				for (const e of entries) {
					if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
				}
			}, { threshold: 0.12 });
			document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

			document.getElementById('theme-toggle')?.addEventListener('click', () => {
				const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
				document.documentElement.dataset.theme = next;
				localStorage.setItem('starlight-theme', next);
			});
		</script>
	</body>
</html>
